{
  "name": "slideshow",
  "version": "0.1.0",
  "description": "Deterministic, privacy-first photo and video slideshow generator built with Remotion and FFmpeg.",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/feliperun/slideshow.git"
  },
  "bugs": {
    "url": "https://github.com/feliperun/slideshow/issues"
  },
  "homepage": "https://github.com/feliperun/slideshow#readme",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.4.0",
  "type": "module",
  "scripts": {
    "dev": "tsx src/cli/index.ts preview",
    "analyze": "tsx src/cli/index.ts analyze",
    "preview": "tsx src/cli/index.ts preview",
    "render": "tsx src/cli/index.ts render",
    "render:thumbnail": "tsx src/cli/index.ts render-thumbnail",
    "render:scene": "tsx src/cli/index.ts render-scene",
    "validate": "tsx src/cli/index.ts validate",
    "clean-cache": "tsx src/cli/index.ts clean-cache",
    "demo:generate": "tsx scripts/generate-demo.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "check": "pnpm typecheck && pnpm test && pnpm lint"
  },
  "dependencies": {
    "@remotion/bundler": "4.0.489",
    "@remotion/cli": "4.0.489",
    "@remotion/renderer": "4.0.489",
    "commander": "15.0.0",
    "exifreader": "4.41.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "remotion": "4.0.489",
    "sharp": "0.35.3",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "10.7.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "globals": "17.7.0",
    "prettier": "3.9.5",
    "tsx": "4.23.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.64.0",
    "vitest": "4.1.10"
  }
}
